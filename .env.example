# Environment
NODE_ENV=local
PORT=8000
LOG_LEVEL=debug

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Dev team allowlist (comma-separated emails). These accounts bypass the store
# economy limits: the 3-ticket cap, the 3-per-24h ticket-pack purchase cooldown,
# and the coin-balance check. Matched case-insensitively. Leave empty to disable.
DEV_UNLIMITED_EMAILS=nikusha13.talakhadze@gmail.com,tsirgvaabrama@gmail.com,eloshaman@gmail.com,tazigrigolia@gmail.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# Per Railway replica. For two replicas this defaults to 24 possible app
# connections total, leaving room below Supabase/Postgres max_connections for
# Auth, Storage, PostgREST, Realtime, observability, and administrative clients.
DB_POOL_MAX=12
DB_INFLIGHT_LIMIT=12
DB_QUEUE_LIMIT=12
DB_ACQUIRE_TIMEOUT_MS=1500
DB_MAX_LIFETIME_SECONDS=1800
DB_WATCHDOG_ENABLED=true
DB_WATCHDOG_INTERVAL_MS=10000
DB_WATCHDOG_TIMEOUT_MS=4000
DB_WATCHDOG_FAILURES=3

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Non-production only. Lets the chaos fleet bypass per-IP API/auth rate limits.
# The backend ignores this in prod even if accidentally configured there.
CHAOS_BYPASS_TOKEN=

# SMSOffice (Georgian phone OTP via Supabase Send SMS hook)
SMSOFFICE_API_KEY=
SMSOFFICE_SENDER=QuizBall
SUPABASE_SMS_HOOK_SECRET=

# JWT Verification (all optional - if not set, uses introspection fallback)
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
SUPABASE_JWKS_URL=https://xxx.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://xxx.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Redis (for WebSocket adapter and ranked queue)
REDIS_URL=redis://:changeme@localhost:6379
RANKED_HUMAN_QUEUE_ENABLED=false
REDIS_PASSWORD=changeme
REDIS_COMMANDER_PASSWORD=devpassword

# API Documentation (Swagger)
# Set DOCS_ENABLED=false to completely disable docs in production
DOCS_ENABLED=true
# Set username/password to protect docs with Basic Auth (recommended for production)
# If not set, docs are accessible without authentication (fine for local dev)
DOCS_USERNAME=
DOCS_PASSWORD=

# PostHog Analytics (backend events)
POSTHOG_API_KEY=phc_YOUR_PROJECT_API_KEY_HERE
POSTHOG_HOST=https://us.i.posthog.com

# New Relic APM & Logging
NEW_RELIC_APP_NAME=quizball
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_ENABLED=true

# Stripe (Store payments)
# Keep these in env only. Never commit real Stripe keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/store?purchase=success
STRIPE_CANCEL_URL=http://localhost:3000/store?purchase=cancelled

# Ops daily report email (Resend). Used by POST /api/v1/internal/ops/daily-report.
# RESEND_API_KEY: Resend transactional API key (re_...).
# RESEND_FROM_EMAIL: verified sender, e.g. "Quizball Ops <ops@quizball.io>".
# OPS_REPORT_TOKEN: long random shared secret the scheduled report agent sends
#   in the x-ops-report-token header. Endpoint fails closed if this is unset.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Quizball Ops <ops@quizball.io>
OPS_REPORT_TOKEN=
# FEEDBACK_RECIPIENT_EMAIL: where player contact/bug-report submissions are emailed.
FEEDBACK_RECIPIENT_EMAIL=support@example.com
