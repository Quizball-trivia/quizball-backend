# Environment
NODE_ENV=local
PORT=8000
LOG_LEVEL=debug

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT Verification (all optional - if not set, uses introspection fallback)
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
SUPABASE_JWKS_URL=https://xxx.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://xxx.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
