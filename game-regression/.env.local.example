# Local regression-harness environment (isolated local Supabase stack).
# Bring the stack up from backend-node/ with:  supabase start
# (config lives in backend-node/supabase/config.toml; migrations auto-apply.)
#
# Copy to .env.local and source it for the LOCAL runner. These point at the local
# Supabase Postgres + the local Redis container — NEVER staging.

# Local Supabase Postgres (from `supabase start` output, port 54322)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Local Redis (docker-compose redis service; password from backend-node/.env REDIS_PASSWORD)
REDIS_URL="redis://default:changeme@127.0.0.1:6379"

# Engine flags the harness needs
NODE_ENV="local"
RANKED_HUMAN_QUEUE_ENABLED="true"

# Notes:
# - questions table starts EMPTY on a fresh local DB → the harness seeds fixed
#   question/category fixtures (also pins ORDER BY RANDOM() determinism).
# - tickets/coins are columns on the `users` table → seed a ticket per scenario via
#   UPDATE users SET tickets = N.
