# Local regression-harness environment — FULLY NATIVE (no Docker).
#
# Postgres: native Homebrew postgresql@16 on :5432, DB `quizball_regression`.
#   brew services start postgresql@16
# Redis: native Homebrew redis on :6379 with password `changeme`.
#   redis-server --port 6379 --requirepass changeme --daemonize yes
# (See game-regression/STATUS.md "Local stack (native, no Docker)" for full setup.)
#
# Copy to .env.local and source it for the LOCAL runner. NEVER staging.

# Native Postgres (regression DB, migrations applied)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/quizball_regression"

# Native Redis (password matches backend-node/.env REDIS_PASSWORD=changeme)
REDIS_URL="redis://:changeme@127.0.0.1:6379"

# Engine flags the harness needs
NODE_ENV="local"
RANKED_HUMAN_QUEUE_ENABLED="true"

# Notes:
# - questions table starts EMPTY on a fresh DB → the harness seeds fixtures.
# - tickets/coins are columns on the `users` table → seeded per scenario.
