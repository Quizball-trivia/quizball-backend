{
  "name": "quizball-backend",
  "version": "1.0.0",
  "description": "QuizBall Backend - Express + TypeScript",
  "main": "dist/bootstrap.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/bootstrap.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:migrate:new": "supabase migration new",
    "db:migrate:status": "supabase migration list",
    "db:migrate:status:remote": "supabase migration list --linked",
    "db:migrate:up": "supabase db push",
    "db:migrate:up:remote": "supabase db push --linked",
    "db:reset": "supabase db reset",
    "db:reset:remote": "supabase db reset --linked",
    "db:diff": "supabase db diff",
    "db:diff:remote": "supabase db diff --linked",
    "db:types": "supabase gen types typescript --local > src/db/database.types.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/db/database.types.ts",
    "audit:backfill-question-types": "tsx scripts/backfill-question-audit-types.ts",
    "docker:start": "./scripts/docker-start.sh",
    "docker:stop": "./scripts/docker-stop.sh",
    "docker:logs": "docker compose logs -f api",
    "api:export": "tsx scripts/export-openapi.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.65.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.206.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@asteasolutions/zod-to-openapi": "^7.0.0",
    "@newrelic/browser-agent": "^1.309.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jose": "^5.9.0",
    "lru-cache": "^11.2.4",
    "newrelic": "^13.12.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "postgres": "^3.4.8",
    "posthog-node": "^5.24.11",
    "redis": "^4.6.12",
    "socket.io": "^4.7.5",
    "stripe": "^20.3.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.7.5",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
